# ============================================
# DivineVedic AI Bot - Environment Variables
# ============================================
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. Never commit .env to git (it's in .gitignore)
# ============================================

# ---- OpenRouter API (Qwen) ----
# Get your key from: https://openrouter.ai/
# Format: sk-or-xxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=

# Model to use (recommended: qwen/qwen2.5-7b-instruct)
# Other options: qwen/qwen-plus, qwen/qwen-max
OPENROUTER_MODEL=qwen/qwen2.5-7b-instruct

# Maximum tokens in response (2000 = ~1500 words)
OPENROUTER_MAX_TOKENS=2000

# Temperature: 0.0 (deterministic) to 1.0 (creative)
OPENROUTER_TEMPERATURE=0.7

# ---- WhatsApp Cloud API ----
# Get from: https://developers.facebook.com/
# Your custom verify token (create your own, e.g., "divinevedic_verify_2024")
WHATSAPP_VERIFY_TOKEN=

# Permanent access token (generate in Meta Developer Console)
WHATSAPP_ACCESS_TOKEN=

# Phone Number ID (from WhatsApp Cloud API setup)
WHATSAPP_PHONE_NUMBER_ID=

# Business Account ID (from WhatsApp Cloud API setup)
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Your public webhook URL (will be set after deployment)
# Local testing: https://abc123.ngrok.io/chat/webhook/whatsapp
# Production: https://your-domain.railway.app/chat/webhook/whatsapp
WHATSAPP_WEBHOOK_URL=

# ---- Firebase / Firestore ----
# Path to your Firebase service account JSON file
# Download from: Firebase Console → Project Settings → Service Accounts
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Your Firebase project ID (from Firebase Console)
FIREBASE_PROJECT_ID=

# Firebase database URL (usually auto-generated)
FIREBASE_DATABASE_URL=

# ---- Razorpay Payment Gateway ----
# Get from: https://dashboard.razorpay.com/
# Test mode keys start with "rzp_test_"
RAZORPAY_KEY_ID=rzp_test_

# Key secret (keep this very secure!)
RAZORPAY_KEY_SECRET=

# Webhook secret (for signature verification)
RAZORPAY_WEBHOOK_SECRET=

# Your public webhook URL for Razorpay
# Local: https://abc123.ngrok.io/webhook/razorpay
# Production: https://your-domain.railway.app/webhook/razorpay
RAZORPAY_WEBHOOK_URL=

# ---- Subscription Settings ----
# Free trial duration (in minutes)
TRIAL_DURATION_MINUTES=5

# Plan 1: ₹199 - 10 minutes talk time
PLAN_199_DURATION_MINUTES=10

# Plan 2: ₹499 - 30 minutes + 3 questions (Most Popular)
PLAN_499_DURATION_MINUTES=30
PLAN_499_QUESTIONS=3

# Plan 3: Pro Plan - ₹999 - 1 month unlimited
PLAN_PRO_DURATION_DAYS=30
PLAN_PRO_PRICE=999

# ---- Security ----
# Secret key for signing tokens (generate a random string)
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=

# Enable webhook signature verification (True for production)
WEBHOOK_SIGNATURE_VERIFICATION=True

# ---- App Settings (Optional) ----
APP_NAME=DivineVedic AI Bot
APP_VERSION=2.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ============================================
# SETUP CHECKLIST:
# ============================================
# [ ] 1. Get OpenRouter API key from https://openrouter.ai/
# [ ] 2. Setup WhatsApp Business API from Meta Developers
# [ ] 3. Create Firebase project and download credentials
# [ ] 4. Create Razorpay account and get API keys
# [ ] 5. Fill in all the values above
# [ ] 6. Save this file as .env
# [ ] 7. Run: python test_app.py
# [ ] 8. Run: uvicorn app.main:app --reload --host 0.0.0.0 --port 8000
# [ ] 9. Test: http://localhost:8000/health
# [ ] 10. Deploy and configure WhatsApp webhook!
# ============================================
